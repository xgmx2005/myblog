---
import PageLayout from '@/layouts/CommonPage.astro'
import GuestbookDotGrid from '@/components/guestbook/GuestbookDotGrid.jsx'
import WalineThread from '@/components/waline/WalineThread.astro'
---

<PageLayout title='留言板' pageId='guestbook'>
  <div slot='background' class='guestbook-backdrop' aria-hidden='true'>
    <GuestbookDotGrid client:only='react' />
  </div>

  <p>欢迎来这里打个招呼。留言公开可见，登录后可以发布。</p>
  <WalineThread path='/guestbook' reaction={false} title='伙伴留言' />
</PageLayout>

<style is:global>
  body[data-page='guestbook'] {
    --guestbook-surface: #eaf8fa;
    --guestbook-dot: rgb(79 157 177 / 72%);
    --guestbook-panel: rgb(249 255 255 / 78%);
    --guestbook-panel-border: rgb(255 255 255 / 88%);
    background-color: var(--guestbook-surface);
  }

  body[data-page='guestbook'] #main-container {
    position: relative;
    z-index: 1;
  }

  body[data-page='guestbook'] .guestbook-backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    background-color: var(--guestbook-surface);
    background-image: radial-gradient(circle, var(--guestbook-dot) 2px, transparent 2.2px);
    background-position: center;
    background-size: 26px 26px;
  }

  html.dark body[data-page='guestbook'] {
    --guestbook-surface: #121017;
    --guestbook-dot: rgb(48 40 63 / 88%);
    --guestbook-panel: rgb(21 18 29 / 78%);
    --guestbook-panel-border: rgb(125 102 180 / 18%);
    background-color: var(--guestbook-surface);
  }

  body[data-page='guestbook'] #content-header,
  body[data-page='guestbook'] #content {
    border: 1px solid var(--guestbook-panel-border);
    border-radius: calc(var(--radius) + 0.5rem);
    background: var(--guestbook-panel);
    box-shadow: 0 1.25rem 4rem rgb(24 93 105 / 11%);
    backdrop-filter: blur(1.15rem) saturate(118%);
  }

  body[data-page='guestbook'] #content-header {
    padding: 1.25rem 1.5rem;
  }

  body[data-page='guestbook'] #content {
    margin-top: 1rem;
    padding: 1.5rem;
  }

  html.dark body[data-page='guestbook'] #content-header,
  html.dark body[data-page='guestbook'] #content {
    border-color: var(--guestbook-panel-border);
    background: var(--guestbook-panel);
    box-shadow: 0 1.25rem 4rem rgb(0 0 0 / 32%);
  }

  @media (max-width: 640px) {
    body[data-page='guestbook'] #content-header,
    body[data-page='guestbook'] #content {
      border-radius: calc(var(--radius) + 0.25rem);
    }

    body[data-page='guestbook'] #content-header {
      padding: 1rem;
    }

    body[data-page='guestbook'] #content {
      padding: 1rem;
    }
  }
</style>
