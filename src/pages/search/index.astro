---
import { PFSearch } from 'astro-pure/components/pages'
import { Button } from 'astro-pure/user'
import DocSearch from '@/components/search/DocSearch.astro'
import PageLayout from '@/layouts/BaseLayout.astro'
import { searchConfig } from '@/lib/search/config'
import { integ } from '@/site-config'

const meta = {
  description: 'Search relative posts of the whole blog',
  title: '搜索'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/blog' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>搜索</h1>
    </div>

    <div id='content' class='animate'>
      {
        searchConfig.mode === 'algolia' && searchConfig.algolia ? (
          <DocSearch {...searchConfig.algolia} />
        ) : integ.pagefind ? (
          <>
            <p>输入关键词搜索全部文章。</p>
            <PFSearch />
          </>
        ) : (
          <p>搜索功能未启用。</p>
        )
      }
    </div>
  </main>
</PageLayout>
